acme.validation.header.message  	= Must have from 1 to 75 characters
acme.validation.text.message   		= Must have from 1 to 255 characters

acme.validation.ticker.message		= The ticker must follow the pattern: 2 uppercase letters, 2 digits, a -, and from 5 to 10 characters (alphanumeric or _)

#campaign
acme.validation.hasMilestones.message = The campaign must have at least 1 milestone associated to be published
acme.validation.campaign.start-after-end.message = The end moment must be after start moment
acme.validation.campaign.ticker-not-unique.message = The ticker must be unique
